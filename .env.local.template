# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# Application Configuration
# ============================================

# Node environment (development, production, test)
NODE_ENV=development

# Next.js configuration
NEXT_PUBLIC_APP_NAME="Đại Chiến Sử Việt - Hào Khí Đông A"
NEXT_PUBLIC_APP_VERSION=0.1.0

# ============================================
# Game Configuration
# ============================================

# Auto-save interval in milliseconds (default: 5 minutes)
NEXT_PUBLIC_AUTOSAVE_INTERVAL=300000

# Enable debug mode for game development
NEXT_PUBLIC_DEBUG_MODE=false

# Enable performance monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# Maximum save slots
NEXT_PUBLIC_MAX_SAVE_SLOTS=5

# ============================================
# Cloud Storage (Optional - Supabase)
# ============================================

# Enable cloud saves (set to 'true' to enable)
NEXT_PUBLIC_ENABLE_CLOUD_SAVES=false

# Supabase configuration (only needed if cloud saves enabled)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Cloud Storage (Optional - Firebase)
# ============================================

# Firebase configuration (alternative to Supabase)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================
# Analytics (Optional)
# ============================================

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ============================================
# Feature Flags
# ============================================

# Enable experimental features
NEXT_PUBLIC_ENABLE_WEB_SPEECH=true
NEXT_PUBLIC_ENABLE_MULTIPLAYER=false
NEXT_PUBLIC_ENABLE_LEADERBOARD=false

# ============================================
# API Configuration
# ============================================

# API base URL (if using external APIs)
NEXT_PUBLIC_API_BASE_URL=

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=10000

# ============================================
# Development Tools
# ============================================

# Enable React Query DevTools
NEXT_PUBLIC_ENABLE_REACT_QUERY_DEVTOOLS=true

# Enable Zustand DevTools
NEXT_PUBLIC_ENABLE_ZUSTAND_DEVTOOLS=true

# ============================================
# Asset Configuration
# ============================================

# CDN URL for assets (leave empty to use local assets)
NEXT_PUBLIC_ASSET_CDN_URL=

# Image optimization quality (1-100)
NEXT_PUBLIC_IMAGE_QUALITY=85

# ============================================
# Security
# ============================================

# Enable CORS (for API routes)
NEXT_PUBLIC_ENABLE_CORS=false

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# Notes
# ============================================
# 
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Server-only variables (without NEXT_PUBLIC_) are only available in API routes and server components
# - Never commit .env.local to version control
# - Restart the development server after changing environment variables
